<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Healthy_Tips">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Healthy Recepies"
            android:textColor="#ffffff"
            android:background="#000000"
            android:textSize="25dp"
            android:padding="10dp"
            android:layout_marginTop="20sp"/>
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:src="@drawable/image6"
            android:scaleType="centerCrop"/>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="20sp"
            android:text="Healthy Recipies\n1.fruit salads\nA mix of fresh fruits like bananas apples oranges\n 2.Low grilled chicjen served with vegetables\n 3.Choma chapo \n 4.Chlorophyl\n Toasted butter bread \nFish sticks "
            />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>